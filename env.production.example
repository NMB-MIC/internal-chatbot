
# MIC 9000 production environment template
# Copy to .env.production and edit values.

# Core app
APP_NAME="MIC 9000"
APP_ENV=production
DEBUG=false

# Runtime
MIC_INDEX_MODE=production
HOST=0.0.0.0
PORT=8000
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8000

# Models
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:26b
EMBEDDING_MODEL_NAME=BAAI/bge-m3
HF_TOKEN=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=internal_documents
QDRANT_DENSE_VECTOR_NAME=dense

# Documents / storage
DOCUMENTS_DIR=data/documents
STAGING_DIR=data/staging
SQLITE_DB_PATH=data/sqlite/chat_history.db
INDEX_MANIFEST_DIR=storage/index_manifests
INDEX_QUARANTINE_DIR=storage/index_quarantine
INDEX_SNAPSHOT_ENABLED=true

# Index safety
INDEX_ALLOW_SECRET_DOCUMENTS=false
INDEX_QUARANTINE_SYNTHETIC_IN_PRODUCTION=true
INDEX_QUARANTINE_EXTERNAL_BOOKS_IN_PRODUCTION=true
INDEX_STALE_DOCUMENT_DAYS=365
INDEX_SAFETY_SCAN_MAX_CHARS=200000
INDEX_FAIL_ON_REJECTED_FILES=false

# Document QA defaults
DOCUMENT_SCOPE_DEFAULT_BEHAVIOR=prefer_selected
DOCUMENT_QA_TOP_K_INITIAL=24
DOCUMENT_QA_TOP_K_FINAL=8
DOCUMENT_QA_SIMILARITY_THRESHOLD=0.28
DOCUMENT_QA_CONTEXT_MAX_CHARACTERS=12000

# Security/access control
MIC_SECURITY_ENABLED=true
MIC_DEVELOPER_TOKEN=mic@dev123
MIC_ADMIN_TOKEN=mic@admin123
MIC_SECURITY_PUBLIC_TRACE=false
MIC_SECURITY_PUBLIC_DIAGNOSTICS=false
MIC_DISPLAY_UNLOCK_HINTS=false
MIC_ADMIN_ACTIONS_ENABLED=false

# Ops
MIC_LOG_DIR=logs
MIC_PID_FILE=logs/mic9000.pid
MIC_BACKUP_DIR=storage/backups
MIC_OPS_BUNDLE_DIR=storage/ops_bundles
MIC_CHAINLIT_LOG=logs/chainlit.log
MIC_RELEASE_CHECK_STRICT=true
