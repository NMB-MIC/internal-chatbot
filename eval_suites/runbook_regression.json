{
  "name": "runbook_regression",
  "version": "1.2",
  "description": "Production-style selected-document regression suite for the machine status prediction runbook. Cases run in isolated sessions by default to prevent cross-case memory contamination.",
  "defaults": {
    "selected_document": "developer_support/machine_status_prediction_runbook.md",
    "document_behavior": "strict_selected"
  },
  "cases": [
    {
      "id": "runbook_health_num_features",
      "question": "How many total model input features should the health endpoint report?",
      "tags": [
        "runbook",
        "exact",
        "health"
      ],
      "expected_fragments": [
        "39"
      ],
      "forbidden_fragments": [
        "cannot confirm"
      ],
      "expected_retrieval": {
        "raw_hit_count": 24,
        "accepted_hit_count": 8,
        "similarity_threshold": 0.28,
        "selected_source_path": "developer_support/machine_status_prediction_runbook.md"
      }
    },
    {
