{
  "name": "document_mode_smoke",
  "version": "1.2",
  "description": "Small smoke suite for selected-document behavior and exact source targeting. Uses strict mode for hard source guarantees and min-count assertions for short documents. Cases run in isolated sessions by default to prevent cross-case memory contamination.",
  "cases": [
    {
      "id": "strict_runbook_health",
      "question": "How many total model input features should the health endpoint report?",
      "selected_document": "developer_support/machine_status_prediction_runbook.md",
      "document_behavior": "strict_selected",
      "tags": [
        "strict_selected",
        "runbook"
      ],
      "expected_fragments": [
        "39"
      ],
      "expected_retrieval": {
        "raw_hit_count": 24,
        "accepted_hit_count": 8,
        "similarity_threshold": 0.28,
        "selected_source_path": "developer_support/machine_status_prediction_runbook.md"
      }
    },
    {
      "id": "strict_runbook_mqtt_topic",
      "question": "What is the pipeline raw Kafka topic?",
      "selected_document": "developer_support/machine_status_prediction_runbook.md",
      "document_behavior": "strict_selected",
      "tags": [
        "strict_selected",
        "runbook",
        "exact"
      ],
      "expected_fragments": [
        "iot.machine.status.raw"
      ],
      "forbidden_fragments": [
        "cannot confirm"
      ],
      "expected_retrieval": {
        "raw_hit_count": 24,
        "accepted_hit_count": 8,
        "similarity_threshold": 0.28,
        "selected_source_path": "developer_support/machine_status_prediction_runbook.md"
      },
      "description": "Uses an isolated session so the previous health-endpoint case cannot contaminate the answer."
    },
    {
      "id": "strict_cv_current_company",
      "question": "What is Apiwit's current company?",
      "selected_document": "company_info/Apiwit_Tech_CV.pdf",
      "document_behavior": "strict_selected",
      "tags": [
        "strict_selected",
        "cv"
      ],
      "expected_any_fragments": [
        [
          "NMB",
          "Minebea",
          "NMB-Minebea"
        ]
      ],
      "expected_retrieval": {
        "min_raw_hit_count": 1,
        "min_accepted_hit_count": 1,
        "similarity_threshold": 0.28,
        "selected_source_path": "company_info/Apiwit_Tech_CV.pdf"
      }
    }
  ],
  "isolate_cases": true
}